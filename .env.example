# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# Databricks workspace URL, e.g. https://dbc-xxxxxxxx-xxxx.cloud.databricks.com
# No trailing slash required (the client strips it on load).
DATABRICKS_HOST=

# Personal Access Token for the workspace.
# Rotate regularly; OAuth M2M with a service principal is the production path.
DATABRICKS_TOKEN=
